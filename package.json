{
  "name": "acum-api-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev": "npm run dev --workspace=packages/api",
    "translate": "node scripts/translate-readme.mjs"
  },
  "devDependencies": {
    "typescript": "5.4.5",
    "@types/node": "20.14.0"
  },
  "engines": {
    "node": ">=20"
  }
}
